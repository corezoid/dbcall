{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "$id": "https://schema.corezoid.com/gitcall/dbcall/internal/app/api.json",
    "type": "object",
    "required": [
        "server"
    ],
    "properties": {
        "server": {
            "type": "object",
            "required": [
                "host",
                "port"
            ],
            "properties": {
                "host": {
                    "type": "string"
                },
                "port": {
                    "type": "number",
                    "minimum": 1,
                    "maximum": 65535
                }
            }
        }
    }
}