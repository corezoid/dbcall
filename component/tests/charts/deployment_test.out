# Source: dbcall_release/charts/dbcall/templates/deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: RELEASE-NAME-dbcall-deployment
  labels:
    release: "RELEASE-NAME"
    app: "dbcall"
    tier: "dbcall"
spec:
  selector:
    matchLabels:
      release: "RELEASE-NAME"
      app: "dbcall"
      tier: "dbcall"
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxSurge: 1
      maxUnavailable: 0
  replicas: 1
  template:
    metadata:
      annotations:
        checksum/config: c375f4375e57de613ba7b6b59cd9df662c3b3855a6b3fad384871452f4ab5f70
        prometheus.io/path: "/metrics"
        prometheus.io/port: "9101"
        prometheus.io/scrape: "true"
      labels:
        release: "RELEASE-NAME"
        app: "dbcall"
        tier: "dbcall"
    spec:
      terminationGracePeriodSeconds: 40
      containers:
        - name: main
          imagePullPolicy: "Always"
          image: docker-hub.middleware.biz/gitcall/dbcall:aVersion
          command: [ "/dbcall/dbcall" ]
          args: [ '--config=/dbcall/dbcall.json' ]
          resources:
            limits:
              cpu: 200m
              memory: 200Mi
            requests:
              cpu: 200m
              memory: 200Mi
          volumeMounts:
            - name: 'config'
              mountPath: '/dbcall/dbcall.json'
              subPath: "dbcall.json"
          readinessProbe:
            tcpSocket:
              port: 12345
            initialDelaySeconds: 15
            periodSeconds: 10
            timeoutSeconds: 5
            successThreshold: 1
            failureThreshold: 3
          livenessProbe:
            tcpSocket:
              port: 11234
            initialDelaySeconds: 15
            periodSeconds: 10
            timeoutSeconds: 5
            successThreshold: 1
            failureThreshold: 3
          securityContext:
            runAsUser: 501
            runAsGroup: 501
            runAsNonRoot: true
            readOnlyRootFilesystem: true
            allowPrivilegeEscalation: false
            privileged: false
            capabilities:
              drop:
                - NET_ADMIN
                - SYS_ADMIN
                - MAC_ADMIN
                - SETUID
                - SETGID
                - FOWNER
                - CHOWN
                - MKNOD
      volumes:
        - name: config
          configMap:
            name: RELEASE-NAME-dbcall-config
---
# Source: dbcall_release/charts/dbcall/templates/hpa.yaml
