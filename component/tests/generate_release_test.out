# [REQUIRED]: object.
dbcall:
    # [REQUIRED]
    config:
        # [REQUIRED]: string.
        __dbcall_image_path: null
        # [REQUIRED]: number.
        __dbcall_liveness_port: null
        # [REQUIRED]: number.
        __dbcall_readiness_port: null
        # [REQUIRED]
        api:
            # [REQUIRED]: object.
            server:
                # [REQUIRED]: string.
                host: null
                # [REQUIRED]: number.
                port: null
        # [REQUIRED]
        database:
            # [REQUIRED]: string.
            database: null
            # [REQUIRED]: string.
            host: null
            max-open-conns-per-db: null
            # [REQUIRED]: string.
            password: null
            # [REQUIRED]: integer.
            port: null
            # [REQUIRED]: boolean.
            ssl: null
            # [REQUIRED]: integer.
            timeoutMs: null
            # [REQUIRED]: string.
            username: null
        # [REQUIRED]: number.
        liveness_port: null
        # [REQUIRED]: string.
        name: null
        # [REQUIRED]: string.
        prom_api: null
        # Expose prometheus metrics. There are two ways promapp can work
        #  * scrape - the app starts metrics server that prometheus can scrape (preferred)
        # * push - the app itself sends metrics to prometheus server
        # Alternative settings:
        # 0#
        # [REQUIRED]: boolean.
        # enabled: true
        # [REQUIRED]: string.
        # metrics_host: ''
        # [REQUIRED]: number.
        # metrics_port: 0
        # not_scraped_check_period_sec: 120
        # [REQUIRED]: string.
        # type: 'scrape'

        # 1#
        # [REQUIRED]: boolean.
        # enabled: true
        # [REQUIRED]: string.
        # push_job: ''
        # [REQUIRED]: number.
        # push_period_sec: 60
        # [REQUIRED]: string.
        # push_url: ''
        # [REQUIRED]: string.
        # type: 'push'
        prometheus:
            enabled: false
        # [REQUIRED]
        query_consumer:
            # [REQUIRED]: string.
            host: null
            # [REQUIRED]: string.
            password: null
            # [REQUIRED]: number.
            port: null
            # [REQUIRED]: number.
            prefetch: null
            # [REQUIRED]: string.
            queue_name: null
            # [REQUIRED]: string.
            username: null
            # [REQUIRED]: string.
            vhost: null
        # [REQUIRED]
        query_reply_publisher:
            # [REQUIRED]: string.
            host: null
            # [REQUIRED]: string.
            password: null
            # [REQUIRED]: number.
            port: 5672
            # [REQUIRED]: string.
            username: null
            # [REQUIRED]: string.
            vhost: null
        # [REQUIRED]: number.
        readiness_port: null
        # [REQUIRED]
        services_pimp:
            # [REQUIRED]: string.
            host: null
            # [REQUIRED]: number.
            port: null
            # [REQUIRED]: number.
            timeoutMs: null
        # [REQUIRED]: boolean.
        use_prometheus_metrics: null
release:
    name: 'dbcall_release'
    require:
        dbcall: 'aVersion'
    repositories:
        dbcall:
            source: 'local'
            local:
                path: '../'
